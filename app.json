      }
    },
    "android": {
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/salonbooklogo.png",
        "backgroundColor": "#963b52"
      },
      "package": "com.salonbook.app.pakistan",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBu5bVS-T3rrXTrnU4DqqTogXFqFDu56r8"
        }
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/salonbooklogo.png",
          "color": "#963b52"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "70172727359-98j9ua46507j84kfhg39o39sfvhhcilt.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.70172727359-98j9ua46507j84kfhg39o39sfvhhcilt"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5bd8d340-4ce4-4079-8720-9c46a9f2d36f"
