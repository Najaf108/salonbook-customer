{
  "expo": {
    "name": "SalonBook",
    "slug": "salonbook",
    "scheme": "salonbook",
    "version": "1.0.2",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/5bd8d340-4ce4-4079-8720-9c46a9f2d36f",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
